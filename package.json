{
  "name": "stand_alone_pets",
  "productName": "Stand_Alone_Pets",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:electron && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "openai": "^6.9.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "concurrently": "^9.2.1",
    "electron": "^38.1.2",
    "typescript": "^5.9.2",
    "vite": "^6.3.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  }
}
